{
  "name": "track_n_trace_frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "homepage": ".",
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@material-tailwind/react": "^2.1.10",
    "@mui/icons-material": "^6.1.1",
    "@mui/material": "^6.1.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.7.7",
    "d3-scale": "^4.0.2",
    "install": "^0.13.0",
    "npm": "^10.8.2",
    "otp-input-react": "^0.3.0",
    "qrcode.react": "^4.0.1",
    "rc-pagination": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.3.0",
    "react-modal": "^3.16.1",
    "react-native-otp-input": "^1.0.12",
    "react-native-phone-input": "^1.3.7",
    "react-paginate": "^8.2.0",
    "react-phone-input-2": "^2.15.1",
    "react-router-dom": "^6.26.1",
    "react-scripts": "5.0.1",
    "react-simple-maps": "^3.0.0",
    "react-tooltip": "^5.29.1",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:react": "react-scripts start",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm run start:react\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "react-scripts build && node verify-build.js",
    "build:production": "REACT_APP_BACKEND_URL=https://test.richi.life react-scripts build && node verify-build.js",
    "dist": "cross-env NODE_ENV=production npm run build && electron-builder",
    "dist:mac": "cross-env NODE_ENV=production npm run build && electron-builder --mac",
    "dist:win": "cross-env NODE_ENV=production npm run build && electron-builder --win",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.realntested.trackntrace",
    "productName": "Track n Trace",
    "files": [
      "build/**/*",
      "electron-main.js",
      "preload.js",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "babel-jest": "^30.0.5",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "cypress": "^14.5.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "jest": "^27.5.1",
    "tailwindcss": "^3.4.10",
    "wait-on": "^8.0.5"
  }
}
